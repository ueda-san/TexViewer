        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="texviewer_tiff">
            <uap:SupportedFileTypes>
              <uap:FileType ContentType="image/tiff">.tiff</uap:FileType>
              <uap:FileType ContentType="image/tiff">.tif</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>Tagged Image File Format file</uap:DisplayName>
            <uap:Logo>Assets\Icons\tiff.png</uap:Logo>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="texviewer_webp">
            <uap:SupportedFileTypes>
              <uap:FileType ContentType="image/webp">.webp</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>Weppy image format file</uap:DisplayName>
            <uap:Logo>Assets\Icons\webp.png</uap:Logo>
          </uap:FileTypeAssociation>
        </uap:Extension>

        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="texviewer_apng">
            <uap:SupportedFileTypes>
              <uap:FileType ContentType="image/apng">.apng</uap:FileType>
            </uap:SupportedFileTypes>
