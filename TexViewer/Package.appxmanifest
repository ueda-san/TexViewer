        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="texviewer_ktx2">
            <uap:SupportedFileTypes>
              <uap:FileType ContentType="image/ktx2">.ktx2</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>Khronos Texture 2.0 file</uap:DisplayName>
            <uap:Logo>Assets\Icons\ktx2.png</uap:Logo>
