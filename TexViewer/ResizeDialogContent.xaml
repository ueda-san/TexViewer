<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TexViewer.ResizeDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TexViewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <RadioButton x:Uid="ResizeBYPercentage" GroupName="Type"
                     Margin="00,10,0,0"
                     IsChecked="True"
                     Checked="RadioButton1_Checked"/>
        <StackPanel Orientation="Horizontal"
                    Margin="30,0,0,0" >
            <TextBlock x:Uid="ResizeWidth"
                       VerticalAlignment="Center"/>
            <TextBox
                x:Name="ResizeWidthPercent"
                TextChanged="ResizeWidthPercent_TextChanged"
                LostFocus="ResizeWidthPercent_LostFocus"
                VerticalAlignment="Center"
                Text="100" />
            <TextBlock Text="%" VerticalAlignment="Center"  Margin="0,0,20,0"/>
            <TextBlock x:Uid="ResizeHeight"
                       VerticalAlignment="Center"/>
            <TextBox
                x:Name="ResizeHeightPercent"
                TextChanged="ResizeHeightPercent_TextChanged"
                LostFocus="ResizeHeightPercent_LostFocus"
                VerticalAlignment="Center"
                Text="100" />

            <TextBlock Text="%" VerticalAlignment="Center"/>
        </StackPanel>

        <RadioButton x:Uid="ResizeBYDimensions" GroupName="Type"
                     Margin="00,10,0,0"
                     Checked="RadioButton2_Checked"/>
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="30,0,0,0" >
            <TextBlock x:Uid="ResizeWidth" VerticalAlignment="Center"/>
            <TextBox
                x:Name="ResizeWidthPix"
                TextChanged="ResizeWidthPix_TextChanged"
                LostFocus="ResizeWidthPix_LostFocus"
                VerticalAlignment="Center"
                IsEnabled="False"
                Text="" />
            <TextBlock Text="pix" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock x:Uid="ResizeHeight" VerticalAlignment="Center"/>
            <TextBox
                x:Name="ResizeHeightPix"
                TextChanged="ResizeHeightPix_TextChanged"
                LostFocus="ResizeHeightPix_LostFocus"
                VerticalAlignment="Center"
                IsEnabled="False"
                Text="" />
            <TextBlock Text="pix" VerticalAlignment="Center"/>
        </StackPanel>

        <CheckBox x:Name="ResizeAspect"
                  x:Uid="ResizeKeepAspect"
                  IsChecked="True"
                  Margin="0,20,0,0"
                  Checked="ResizeAspect_Checked"
                  Unchecked="ResizeAspect_Unchecked" />

        <StackPanel Orientation="Horizontal"
                    Margin="0,20,0,0"
                    VerticalAlignment="Center" >
            <TextBlock x:Uid="ResizeFilter"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="FilterComboBox"
                      ItemsSource="{x:Bind FilterCollection}"
                      SelectionChanged="ComboBox_SelectionChanged"
                      VerticalAlignment="Center"
                      SelectedIndex="0"
                      Width="200" Loaded="ResizeFilter_Loaded"/>
        </StackPanel>

    </StackPanel>

</Page>
