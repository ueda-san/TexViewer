<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TexViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TexViewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TexViewer">

    <Grid KeyboardAcceleratorPlacementMode="Hidden"
          ActualThemeChanged="Grid_ActualThemeChanged">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="OnPasteInvoked"/>
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyInvoked"/>
            <KeyboardAccelerator Key="P" Modifiers="Control" Invoked="OnPrevKeyInvoked"/>
            <KeyboardAccelerator Key="N" Modifiers="Control" Invoked="OnNextKeyInvoked"/>
            <KeyboardAccelerator Key="Left" Invoked="OnPrevKeyInvoked"/>
            <KeyboardAccelerator Key="Right" Invoked="OnNextKeyInvoked"/>
            <KeyboardAccelerator Key="Up" Invoked="OnPrevKeyInvoked"/>
            <KeyboardAccelerator Key="Down" Invoked="OnNextKeyInvoked"/>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscKeyInvoked"/>
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <local:CustomGrid x:Name="RootGrid"
                          Grid.Row="0"
                          IsTabStop="True"
                          Background="Cyan"
                          AllowDrop="True"
                          DragOver="DragOver"
                          Drop="DropAsync">
            <Grid.ContextFlyout>
                <MenuFlyout Opening="MenuFlyout_Opening"
                            Closed="MenuFlyout_Closed">
                    <MenuFlyoutItem x:Uid="ContextColor"
                                    Click="ContextMenu_ColorPicker">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE790;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <ToggleMenuFlyoutItem x:Uid="ContextTransparent"
                                          Click="ContextMenu_Checker"
                                          IsChecked="False">
                        <ToggleMenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE7B3;"/>
                        </ToggleMenuFlyoutItem.Icon>
                    </ToggleMenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="FlyoutResize"
                                    x:Uid="ContextResize"
                                    IsEnabled="False"
                                    Click="ContextMenu_Resize">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE744;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="FlyoutRotate"
                                    x:Uid="ContextRotate"
                                    IsEnabled="False"
                                    Click="ContextMenu_Rotate">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE7AD;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSubItem x:Name="FlyoutFlip"
                                       x:Uid="ContextFlip"
                                       IsEnabled="False">
                        <MenuFlyoutSubItem.Icon>
                            <FontIcon Glyph="&#xE746;"/>
                        </MenuFlyoutSubItem.Icon>
                        <MenuFlyoutItem x:Uid="Horizontal" Click="ContextMenu_Flop"/>
                        <MenuFlyoutItem x:Uid="Vertical" Click="ContextMenu_Flip"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutItem x:Name="FlyoutInfo"
                                    x:Uid="ContextInfo"
                                    IsEnabled="False"
                                    Click="ContextMenu_Info">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE946;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <ToggleMenuFlyoutItem x:Name="FlyoutAnimation"
                                          Visibility="Visible"
                                          x:Uid="ContextAnimation"
                                          Click="ContextMenu_Animation"
                                          IsEnabled="False"
                                          IsChecked="False">
                        <ToggleMenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE768;"/>
                        </ToggleMenuFlyoutItem.Icon>
                    </ToggleMenuFlyoutItem>
                    <ToggleMenuFlyoutItem x:Name="FlyoutAnimationPause"
                                          Visibility="Collapsed"
                                          x:Uid="ContextAnimationPause"
                                          Click="ContextMenu_Animation"
                                          IsEnabled="True"
                                          IsChecked="False">
                        <ToggleMenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE769;"/>
                        </ToggleMenuFlyoutItem.Icon>
                    </ToggleMenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="FlyoutCrop"
                                    x:Uid="ContextCrop"
                                    IsEnabled="False"
                                    Click="ContextMenu_Crop">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE7A8;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="FlyoutMosaic"
                                    x:Uid="ContextMosaic"
                                    IsEnabled="False"
                                    Click="ContextMenu_Mosaic">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xEA18;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="FlyoutUndo"
                                    x:Uid="ContextUndo"
                                    Icon="Undo"
                                    Click="ContextMenu_Undo">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="Z"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>

                    <MenuFlyoutItem x:Uid="ContextOpen"
                                    Icon="OpenFile"
                                    Click="ContextMenu_Open">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="O" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="FlyoutSave"
                                    x:Uid="ContextSave"
                                    Icon="Save"
                                    Click="ContextMenu_Save">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="S" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Grid.ContextFlyout>
            <Grid x:Name="SwapChainRoot"
                  Background="White">
                <SwapChainPanel x:Name="ImagePanel"
                                Visibility="Visible"
                                Loaded="ImagePanel_Loaded"
                                Unloaded="ImagePanel_Unloaded" />
            </Grid>
            <InfoBar x:Name="ErrorBar" IsOpen="False" Title="Error" Severity="Error" />
        </local:CustomGrid>

        <CommandBar x:Name="MainCommandBar"
                    Loaded="MainCommandBar_Loaded"
                    Grid.Row="1"
                    VerticalContentAlignment="Center"
                    Canvas.ZIndex="1">
            <CommandBar.Resources>
                <Style TargetType="AppBarButton">
                    <Setter Property="Width" Value="32" />
                    <Setter Property="LabelPosition" Value="Collapsed" />
                </Style>
                <Style TargetType="AppBarToggleButton">
                    <Setter Property="Width" Value="32" />
                    <Setter Property="LabelPosition" Value="Collapsed" />
                </Style>
            </CommandBar.Resources>
            <CommandBar.Content>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe UI" Margin="4,0">
                        <Run Text="(0,0)" x:Name="InfoTextPos"/>
                        <Run Text=" #FFFFFF" x:Name="InfoTextCol" />
                    </TextBlock>
                    <TextBlock x:Name="RectText"
                               FontFamily="Segoe UI"
                               Foreground="CornflowerBlue"
                               Text=""
                               Margin="2,0"/>
                </StackPanel>
            </CommandBar.Content>
            <AppBarSeparator/>
            <AppBarElementContainer x:Name="ZoomElementContainer"
                                    Visibility="Visible"
                                    Tapped="ZoomText_Tapped"
                                    VerticalContentAlignment="Center">
                <TextBlock x:Name="ZoomText"
                           Text="🔍100%"
                           Margin="4,0"/>
            </AppBarElementContainer>


            <AppBarToggleButton x:Name="FitToWindow"
                                Label="Fit To Window"
                                IsChecked="False"
                                Checked="FitToWindow_Checked"
                                Unchecked="FitToWindow_Unchecked">
                <ToolTipService.ToolTip>
                    <ToolTip x:Uid="AppBarFitToWindow"/>
                </ToolTipService.ToolTip>
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE9A6;"/>
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Uid="AppBarPluginManager"
                              Click="PluginManager_Click">
                    <FontIcon Glyph="&#xF19F;"/>
                </AppBarButton>
                <AppBarButton x:Uid="AppBarPreference"
                              Click="Preference_Click">
                    <FontIcon Glyph="&#xE713;"/>
                </AppBarButton>
                <AppBarButton x:Uid="AppBarHelp"
                              Icon="Help"
                              Click="Help_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Grid>
</Window>
